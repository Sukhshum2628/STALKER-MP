    <!-- Engine adapter layer: the only TU including X-Ray headers.
         Compiles with engine include paths; excluded from the test build
         (tests link tests\support\NullEngineAdapters.cpp instead). -->
    <ClCompile Include="src\adapters\EngineAdapters.cpp">
      <!-- Third-party include root for engine headers. xrCore/xrMemory_subst_msvc.h
           and xr_resource.h include <fast_dynamic_cast/fast_dynamic_cast.hpp>, which
           lives under Engine/xray-monolith/src/3rd party. The engine resolves this via
           the "..\src\3rd party" entry on IncludePath in Common.props (line 19); since
           this TU does not import Common.props, that root is replicated here. Scoped to
           the adapter TU only because it is the sole unit that includes engine headers
           (One Engine Boundary). -->
      <!-- Sprint-005: the ALife switch gateway reaches CALifeSimulator /
           CSE_ALifeDynamicObject, which live in xrGame and xrServerEntities. Both
           roots are added here (scoped to this TU only — One Engine Boundary). -->
      <AdditionalIncludeDirectories>$(MSBuildThisFileDirectory)include;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\xrEngine;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\xrGame;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\xrGame\vs2022;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\xrServerEntities;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\xrCore;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\3rd party;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\src\3rd party\luajit-2\src;$(MSBuildThisFileDirectory)..\Engine\xray-monolith\sdk\include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!-- Engine compatibility defines. This TU is the only one that includes
           X-Ray headers, so it must replicate the engine's own compile-time
           opt-ins. These are NOT invented by STALKER-MP; they mirror the engine.
           _SILENCE_STDEXT_HASH_DEPRECATION_WARNINGS:
             Why it exists: xrCore.h (line 197, under #ifndef _EDITOR) includes the
               deprecated MSVC extension header <hash_map>, and _stl_extensions.h
               derives xr_hash_map from stdext::hash_map. Modern MSVC STL emits a
               deprecation diagnostic (STL4041) for these unless this macro is defined.
             Where the engine defines it: Engine/xray-monolith/src/Common.props (line 30),
               inherited by every engine project (xrCore, xrEngine, etc.).
             Why STALKER-MP requires it: the adapter TU reproduces the engine include
               chain but does not import Common.props, so the opt-in must be replicated
               here for <hash_map> to compile the same way it does in the engine build. -->
      <PreprocessorDefinitions>WIN32;_WINDOWS;_SILENCE_STDEXT_HASH_DEPRECATION_WARNINGS;XRGAME_EXPORTS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <WarningLevel>Level3</WarningLevel>
      <TreatWarningAsError>false</TreatWarningAsError>
      <!-- Permissive (non-conformant) name lookup for engine headers. xrCore's
           _vector3d.h / _matrix.h templates reference the global `Device`
           (declared in xrEngine/device.h, a layer above xrCore) as a non-dependent
           name. Under /permissive- these bind at template definition time and fail
           because Device is not visible when xrCore parses. The engine compiles these
           headers in default permissive mode (it sets no ConformanceMode anywhere:
           Common.props, xrCore.vcxproj, xrEngine.vcxproj), which defers the lookup to
           instantiation that never occurs. This mirrors the engine's own compile
           environment. Scoped to the adapter TU only; all Sprint-002 source keeps the
           project-wide ConformanceMode=true (/permissive-) set above (One Engine Boundary). -->
      <ConformanceMode>false</ConformanceMode>
    </ClCompile>
