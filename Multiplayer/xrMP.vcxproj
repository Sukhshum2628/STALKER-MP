    <ProjectConfiguration Include="ProfiledDX11|x64">
      <Configuration>ProfiledDX11</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release-AVX|x64">
